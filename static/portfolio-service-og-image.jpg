<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="1200" height="630" fill="#f6f3ee"/>
  <rect x="50" y="50" width="1100" height="530" rx="20" fill="#ffffff" stroke="#e6e2db" stroke-width="2"/>
  
  <!-- Main Chart Area -->
  <rect x="100" y="150" width="400" height="300" rx="12" fill="#faf8f4" stroke="#d9c2a6" stroke-width="2"/>
  <path d="M150 400L150 250L225 325L300 200L375 275L450 225L450 400L150 400Z" fill="#1b1a18"/>
  <circle cx="225" cy="325" r="15" fill="#ffffff"/>
  <circle cx="300" cy="200" r="15" fill="#ffffff"/>
  <circle cx="375" cy="275" r="15" fill="#ffffff"/>
  <circle cx="450" cy="225" r="15" fill="#ffffff"/>
  
  <!-- Portfolio Items -->
  <rect x="550" y="150" width="600" height="80" rx="8" fill="#faf8f4" stroke="#e6e2db" stroke-width="1"/>
  <text x="570" y="185" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="18" font-weight="600">삼성전자 (005930)</text>
  <text x="570" y="210" fill="#6b6b63" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="14">100주 × ₩72,000 = ₩7,200,000</text>
  <text x="1050" y="185" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="700" text-anchor="end">35%</text>
  
  <rect x="550" y="250" width="600" height="80" rx="8" fill="#faf8f4" stroke="#e6e2db" stroke-width="1"/>
  <text x="570" y="285" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="18" font-weight="600">애플 (AAPL)</text>
  <text x="570" y="310" fill="#6b6b63" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="14">50주 × $180 × 1,350 = ₩12,150,000</text>
  <text x="1050" y="285" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="700" text-anchor="end">60%</text>
  
  <rect x="550" y="350" width="600" height="80" rx="8" fill="#faf8f4" stroke="#e6e2db" stroke-width="1"/>
  <text x="570" y="385" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="18" font-weight="600">TIGER S&P500 (360750)</text>
  <text x="570" y="410" fill="#6b6b63" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="14">10주 × ₩1,350,000 = ₩13,500,000</text>
  <text x="1050" y="385" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="700" text-anchor="end">5%</text>
  
  <!-- Title -->
  <text x="100" y="100" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="48" font-weight="700">보유 종목 계산기</text>
  <text x="100" y="130" fill="#6b6b63" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="24">무료 포트폴리오 관리 및 실시간 주식 가격 조회</text>
  
  <!-- Total -->
  <rect x="100" y="480" width="400" height="60" rx="8" fill="#d9c2a6"/>
  <text x="120" y="515" fill="#ffffff" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="20" font-weight="600">총 보유금액: ₩32,850,000</text>
  <text x="420" y="515" fill="#ffffff" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="18" text-anchor="end">100%</text>
  
  <!-- Features -->
  <text x="550" y="480" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="600">✓ 실시간 주식 가격 조회</text>
  <text x="550" y="505" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="600">✓ 한국/미국 주식, ETF 지원</text>
  <text x="550" y="530" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="600">✓ 자동 환율 적용</text>
  <text x="800" y="480" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="600">✓ 포트폴리오 분석</text>
  <text x="800" y="505" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="600">✓ CSV 데이터 관리</text>
  <text x="800" y="530" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="16" font-weight="600">✓ 모바일 최적화</text>
</svg>
