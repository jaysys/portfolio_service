<svg width="800" height="418" viewBox="0 0 800 418" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="418" fill="#f6f3ee"/>
  <rect x="30" y="30" width="740" height="358" rx="15" fill="#ffffff" stroke="#e6e2db" stroke-width="2"/>
  
  <!-- Chart -->
  <rect x="60" y="100" width="250" height="180" rx="8" fill="#faf8f4" stroke="#d9c2a6" stroke-width="2"/>
