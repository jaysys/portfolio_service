  <circle cx="180" cy="120" r="8" fill="#ffffff"/>
  <circle cx="220" cy="170" r="8" fill="#ffffff"/>
  <circle cx="270" cy="140" r="8" fill="#ffffff"/>
  
  <!-- Portfolio Items -->
  <rect x="340" y="100" width="420" height="50" rx="6" fill="#faf8f4" stroke="#e6e2db" stroke-width="1"/>
  <text x="355" y="125" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="14" font-weight="600">삼성전자 (005930)</text>
  <text x="355" y="142" fill="#6b6b63" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="11">100주 × ₩72,000 = ₩7,200,000</text>
  <text x="720" y="125" fill="#1b1a18" font-family="Apple SD Gothic Neo, Noto Sans KR, sans-serif" font-size="12" font-weight="700" text-anchor="end">35%</text>
  
